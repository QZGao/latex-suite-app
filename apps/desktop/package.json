{
  "name": "@latex-suite/desktop",
  "private": true,
  "version": "0.1.3",
  "description": "IME-like LaTeX composer for Windows.",
  "author": "latex-suite-app contributors",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "test": "vitest run",
    "package:dir": "electron-vite build && node ./scripts/run-electron-builder.mjs --dir --config electron-builder.config.mjs",
    "package:portable": "electron-vite build && node ./scripts/run-electron-builder.mjs --win portable --config electron-builder.config.mjs",
    "dist:win": "electron-vite build && node ./scripts/run-electron-builder.mjs --win nsis portable --config electron-builder.config.mjs"
  },
  "devDependencies": {
    "@codemirror/commands": "^6.9.1",
    "@codemirror/language": "^6.11.3",
    "@codemirror/state": "^6.5.2",
    "@codemirror/view": "^6.38.6",
    "@latex-suite/contracts": "workspace:*",
    "@types/node": "^24.3.0",
    "codemirror": "^6.0.2",
    "electron": "^37.2.6",
    "electron-builder": "^26.0.12",
    "electron-vite": "^4.0.0",
    "jsdom": "^26.1.0",
    "katex": "^0.16.22",
    "typescript": "^5.9.2",
    "vite": "^7.1.3",
    "vitest": "^2.0.5"
  }
}
